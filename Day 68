#include <stdio.h>
#define MAX 100

int adj[MAX][MAX], indegree[MAX], queue[MAX];
int n;

void topoSort()
{
    int front = 0, rear = -1;
    int topo[MAX], count = 0;

    for(int i = 0; i < n; i++)
    {
        if(indegree[i] == 0)
            queue[++rear] = i;
    }

    while(front <= rear)
    {
        int u = queue[front++];
        topo[count++] = u;

        for(int v = 0; v < n; v++)
        {
            if(adj[u][v] == 1)
            {
                indegree[v]--;
                if(indegree[v] == 0)
                    queue[++rear] = v;
            }
        }
    }

    if(count != n)
    {
        printf("Cycle detected! Topological sort not possible.\n");
        return;
    }

    printf("Topological Order: ");
    for(int i = 0; i < count; i++)
        printf("%d ", topo[i]);
}

int main()
{
    int edges, u, v;

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    printf("Enter number of edges: ");
    scanf("%d", &edges);

    for(int i = 0; i < n; i++)
    {
        indegree[i] = 0;
        for(int j = 0; j < n; j++)
            adj[i][j] = 0;
    }

    printf("Enter edges (u v):\n");
    for(int i = 0; i < edges; i++)
    {
        scanf("%d %d", &u, &v);
        adj[u][v] = 1;
        indegree[v]++;
    }

    topoSort();

    return 0;
}
